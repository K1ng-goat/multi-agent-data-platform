# ===== Multi-Agent Data Platform — Environment Variables =====
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docker Compose reads .env automatically.
# For local development, source or export these variables.

# --- Required ---
# DeepSeek API Key (get one at https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# --- JWT ---
# Secret key for signing JWT tokens (change in production)
JWT_SECRET=aiexcel-secret-key-change-in-production

# --- Database ---
# SQLite is used by default. To switch to MySQL/PostgreSQL, set DATABASE_URL.
# DATABASE_URL=sqlite:///./data_agent.db

# --- API ---
# Backend API base URL for the frontend to consume.
# Local:  http://localhost:8001
# Docker: http://localhost:8001 (host port mapped to backend container)
API_BASE_URL=http://localhost:8001

# --- Rate Limiting ---
# RATE_LIMIT_REQUESTS=10
# RATE_LIMIT_WINDOW_SEC=60

# --- File Upload ---
# MAX_UPLOAD_SIZE_MB=50
